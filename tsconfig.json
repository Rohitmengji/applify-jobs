{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["chrome", "node", "react", "react-dom"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "exclude": [
    "node_modules",
    ".output",
    "dist",
    "coverage",
    "e2e",
    "vitest.config.ts",
    "wxt.config.ts",
    "**/*.config.ts",
    "**/*.config.mjs",
    "**/*.config.js"
  ]
}
