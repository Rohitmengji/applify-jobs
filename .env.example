# OneClick Apply — example environment.
#
# The core extension is LOCAL-FIRST and needs NO environment variables.
# The user's LLM API key and optional proxy URL are stored in chrome.storage.local
# from the Options page at runtime — they are NEVER baked into the build or committed.
#
# These optional WXT_PUBLIC_* vars only set *defaults* shown in the Options UI.
# Use a plain host (no scheme, no credentials) to keep secret scanners happy.

# Optional default LLM proxy host shown in Options (e.g. LLM_PROXY_HOST_PLACEHOLDER).
WXT_PUBLIC_LLM_BASE_HOST=

# Optional default model id shown in Options.
WXT_PUBLIC_LLM_MODEL=claude-sonnet-4-6
